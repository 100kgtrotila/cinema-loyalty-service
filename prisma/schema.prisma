generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Tier {
  BRONZE
  SILVER
  GOLD
}

model LoyaltyProfile {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @unique @map("user_id") @db.Uuid

  tier               Tier      @default(BRONZE)
  
  balance            Int       @default(0)
  lifetimePoints     Int       @default(0) @map("lifetime_points")
  yearPoints         Int       @default(0) @map("year_points")
  yearVisits         Int       @default(0) @map("year_visits")

  tierExpiresAt      DateTime? @map("tier_expires_at") @db.Timestamptz()
  lastActivityAt     DateTime? @map("last_activity_at") @db.Timestamptz()
  balanceExpiresAt   DateTime? @map("balance_expires_at") @db.Timestamptz()
  birthdayDate       DateTime? @map("birthday_date") @db.Date
  lastExpiryNotificationAt DateTime? @map("last_expiry_notification_at") @db.Timestamptz()

  goldUpgradeUsedMonth String? @map("gold_upgrade_used_month") @db.VarChar(7)

  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([userId])
  @@index([tier])
  @@map("loyalty_profiles")
}

model ProcessedEvent {
  eventId     String   @id @map("event_id") @db.VarChar(128)
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz()

  @@map("processed_events")
}

model PointsTransaction {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  type         String   @db.VarChar(20)
  points       Int
  balanceAfter Int      @map("balance_after")
  orderId      String?  @map("order_id") @db.Uuid
  description  String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId])
  @@index([createdAt])
  @@map("points_transactions")
}

enum OutboxEventStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model OutboxEvent {
  id            String            @id @default(uuid()) @db.Uuid
  type          String            @db.VarChar(100)
  payload       Json              @db.JsonB
  status        OutboxEventStatus @default(PENDING)
  aggregateType String            @map("aggregate_type") @db.VarChar(100)
  aggregateId   String            @map("aggregate_id") @db.Uuid
  attempts      Int               @default(0) @db.SmallInt
  maxAttempts   Int               @default(5) @map("max_attempts") @db.SmallInt
  error         String?           @db.Text
  publishedAt   DateTime?         @map("published_at") @db.Timestamptz()
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([status, createdAt])
  @@index([aggregateType, aggregateId])
  @@map("outbox_events")
}

enum AchievementCategory {
  VISITS
  SPENDING
  TIER
  TIME
  SPECIAL
  STREAK
  SECRET
}

enum AchievementRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum AchievementStrategy {
  INSTANT
  THRESHOLD
  STREAK
}

model Achievement {
  id           String              @id @default(uuid()) @db.Uuid
  code         String              @unique @db.VarChar(64)

  name         String              @db.VarChar(128)
  description  String              @db.Text
  secretHint   String?             @map("secret_hint") @db.Text
  isSecret     Boolean             @default(false) @map("is_secret")

  icon         String              @db.VarChar(128)
  category     AchievementCategory
  rarity       AchievementRarity   @default(COMMON)
  strategy     AchievementStrategy @default(INSTANT)

  criteria     Json                @db.JsonB

  rewardPoints Int                 @default(0) @map("reward_points")
  sortOrder    Int                 @default(0) @map("sort_order") @db.SmallInt
  isActive     Boolean             @default(true) @map("is_active")

  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz()

  userAchievements UserAchievement[]

  @@index([category])
  @@index([isActive])
  @@map("achievements")
}


model UserAchievement {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  achievementId String      @map("achievement_id") @db.Uuid

  current       Int         @default(0) @db.Integer
  target        Int         @default(1) @db.Integer

  isUnlocked    Boolean     @default(false) @map("is_unlocked")
  unlockedAt    DateTime?   @map("unlocked_at") @db.Timestamptz()

  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz()

  achievement   Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([userId, isUnlocked])
  @@index([achievementId])
  @@map("user_achievements")
}